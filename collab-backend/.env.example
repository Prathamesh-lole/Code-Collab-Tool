PORT=5000
JWT_SECRET=your_jwt_secret_here

# Option A: Full Railway connection URL (Railway provides this automatically)
DATABASE_URL=mysql://user:password@host:port/dbname

# Option B: Individual fields (use if DATABASE_URL is not available)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=collab_code
DB_PORT=3306

# Frontend URL for CORS (your Vercel URL)
FRONTEND_URL=https://your-app.vercel.app
